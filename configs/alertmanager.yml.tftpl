global:
  resolve_timeout: 5m

  smtp_smarthost: "smtp.gmail.com:587"
  smtp_from: "${smtp_email}"
  smtp_auth_username: "${smtp_email}"
  smtp_auth_password: "${smtp_password}"
  smtp_require_tls: true

route:
  receiver: email
  group_wait: 10s
  group_interval: 30s
  repeat_interval: 1h

receivers:
  - name: email
    email_configs:
      - to: "${smtp_email}"
        send_resolved: true
