global:
  scrape_interval: 15s

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - "localhost:9093"

rule_files:
  - "/etc/prometheus/alerts/*.yml"

scrape_configs:
  - job_name: "node"

    static_configs:
      - targets:
          - "${node1_private_ip}:9100"
        labels:
          node: "node1"

      - targets:
          - "${node2_private_ip}:9100"
        labels:
          node: "node2"
